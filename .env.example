# Note - Change these values before running in a shared or production environment

# ==========================================
# POSTGRES CONFIGURATIONS
# ==========================================
POSTGRES_PORT=5432
POSTGRES_DB=your_postgres_db_name
POSTGRES_USER=your_postgres_master_user
POSTGRES_PASSWORD=your_postgres_master_password

AUTH_SERVICE_USER=auth_service_user
AUTH_SERVICE_PASSWORD=your_auth_service_password

ORDER_SERVICE_USER=order_service_user
ORDER_SERVICE_PASSWORD=your_order_service_password

BILLING_SERVICE_USER=billing_service_user
BILLING_SERVICE_PASSWORD=your_billing_service_password

NOTIFICATION_SERVICE_USER=notification_service_user
NOTIFICATION_SERVICE_PASSWORD=your_notification_service_password


# ==========================================
# TIMESCALEDB CONFIGURATIONS
# ==========================================
TIMESCALE_PORT=5433
TIMESCALE_DB=your_timescale_db_name
TIMESCALE_USER=your_timescale_master_user
TIMESCALE_PASSWORD=your_timescale_master_password

MARKET_TICKER_SERVICE_USER=market_service_user
MARKET_TICKER_SERVICE_PASSWORD=your_market_ticker_password

IOT_SERVICE_USER=iot_service_user
IOT_SERVICE_PASSWORD=your_iot_service_password

AI_SERVICE_USER=ai_service_user
AI_SERVICE_PASSWORD=your_ai_service_password


# ==========================================
# KAFKA / EVENT STREAMING CONFIGURATIONS
# ==========================================
KAFKA_PORT=9092
KAFKA_ZOOKEEPER_CONNECT=your_zookeeper_connection_string
KAFKA_ADVERTISED_LISTENERS=your_kafka_advertised_listeners
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1